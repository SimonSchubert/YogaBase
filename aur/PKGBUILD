# Maintainer: Simon Schubert <sschubert89@gmail.com>
# https://github.com/SimonSchubert/YogaBase

pkgname=yogabase-bin
pkgver=0.1.0
pkgrel=1
pkgdesc='Guided yoga sessions with voice, poses, and streak tracking'
arch=('x86_64')
url='https://github.com/SimonSchubert/YogaBase'
license=('MIT')
depends=('hicolor-icon-theme')
provides=('yogabase')
conflicts=('yogabase')
options=('!strip')

source=("YogaBase-${pkgver}-linux-x86_64.tar.gz::https://github.com/SimonSchubert/YogaBase/releases/download/v${pkgver}/YogaBase-${pkgver}-linux-x86_64.tar.gz")
sha256sums=('SKIP')

package() {
    # Install application files
    install -dm755 "${pkgdir}/opt/yogabase"
    cp -r "${srcdir}/YogaBase/"* "${pkgdir}/opt/yogabase/"
    chmod -R go-w "${pkgdir}/opt/yogabase"

    # Install wrapper script
    install -Dm755 /dev/stdin "${pkgdir}/usr/bin/yogabase" << 'EOF'
#!/bin/sh
exec /opt/yogabase/bin/YogaBase "$@"
EOF

    # Install desktop entry
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/yogabase.desktop" << EOF
[Desktop Entry]
Name=YogaBase
Comment=Guided yoga sessions with voice, poses, and streak tracking
Exec=yogabase
Icon=yogabase
Type=Application
Categories=HealthAndFitness;Sports;
Keywords=Yoga;Fitness;Meditation;Stretching;Exercise;Health;
StartupWMClass=compose-window
Terminal=false
EOF

    # Install icon
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/icons/hicolor/scalable/apps/yogabase.svg" << 'EOF'
<svg viewBox="0 0 90 90" xmlns="http://www.w3.org/2000/svg">
   <circle cx="45" cy="45" r="40" fill="#38A169" />
   <text x="45" y="60" text-anchor="middle" font-size="48" font-family="sans-serif" font-weight="bold" fill="#ffffff">Y</text>
</svg>
EOF

    # Install license
    install -Dm644 "${srcdir}/YogaBase/lib/YogaBase.copyright" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" 2>/dev/null ||
    install -Dm644 "${srcdir}/YogaBase/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" 2>/dev/null || true
}

# Publishing steps:
# 1. Create AUR account at https://aur.archlinux.org
# 2. git clone ssh://aur@aur.archlinux.org/yogabase-bin.git
# 3. Copy PKGBUILD and .SRCINFO into the cloned repo
# 4. git add PKGBUILD .SRCINFO
# 5. git commit -m "Initial upload: yogabase-bin 0.1.0"
# 6. git push
